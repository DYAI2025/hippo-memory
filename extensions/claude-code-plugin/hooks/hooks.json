{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hippo context --auto --budget 1500 2>/dev/null || echo 'No hippo store found. Run: hippo init'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "hippo last-sleep 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/capture-error.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hippo session-end 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
